{
  "name": "sqldesc",
  "version": "0.1.0",
  "description": "Infer SQL result-set columns from SQL, bind types, and schema files.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sqldesc": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test --experimental-strip-types 'test/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@polyglot-sql/sdk": "^0.4.3",
    "easy-table": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
